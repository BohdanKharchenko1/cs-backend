{
  "name": "casino-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "install:clean": "rm -rf node_modules && rm yarn.lock && yarn install",
    "start": "node dist/main.js",
    "start:nest": "nest start",
    "start:local": "NODE_ENV=local nest start --watch --noEmitOnError",
    "start:dev": "NODE_ENV=development node dist/main --transpile-only",
    "start:debug": "nest start --debug --watch",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typeorm": "ts-node --require tsconfig-paths/register ./node_modules/typeorm/cli",
    "migration:run": "NODE_ENV=development yarn typeorm migration:run -- -d ./src/database/database.datasource.ts",
    "migration:prod:run": "NODE_ENV=production yarn typeorm migration:run -- -d ./src/shared/database/database.datasource.ts",
    "migration:test:run": "NODE_ENV=local yarn typeorm migration:run -- -d ./src/shared/database/database.datasource.ts",
    "migration:test:generate": "NODE_ENV=local yarn typeorm -- -d ./src/shared/database/database.datasource.ts migration:generate ./src/shared/database/migrations/$npm_config_name",
    "migration:generate": "NODE_ENV=development yarn typeorm migration:generate -d src/database/database.datasource.ts ./src/database/migrations/$npm_config_name",
    "migration:prod:generate": "NODE_ENV=production yarn typeorm -- -d ./src/shared/database/database.datasource.ts migration:generate ./src/shared/database/migrations/$npm_config_name",
    "migration:create": "yarn typeorm -- migration:create ./src/shared/database/migrations/$npm_config_name",
    "migration:revert": "NODE_ENV=development yarn typeorm -- -d ./src/database/database.datasource.ts migration:revert",
    "migration:prod:revert": "NODE_ENV=production yarn typeorm -- -d ./src/shared/database/database.datasource.ts migration:revert",
    "migration:test:revert": "NODE_ENV=local yarn typeorm -- -d ./src/shared/database/database.datasource.ts migration:revert",
    "migration:show": "yarn typeorm migration:show -- -d ./src/shared/database/database.config.ts",
    "migration:prod:show": "NODE_ENV=production yarn typeorm migration:show -- -d ./src/shared/database/database.datasource.ts",
    "test": "NODE_ENV=local jest --runInBand",
    "test:watch": "NODE_ENV=local jest --watch",
    "test:cov": "NODE_ENV=local jest --coverage",
    "test:debug": "NODE_ENV=local node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "NODE_ENV=local jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.8",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.8",
    "@telegram-apps/init-data-node": "^2.0.10",
    "axios": "^1.12.2",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "typeorm": "^0.3.27",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
